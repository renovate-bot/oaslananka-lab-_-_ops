{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repository Autonomy Policy",
  "type": "object",
  "required": ["version", "autonomy", "repository_role", "agent", "pr", "release", "publish", "mirror", "source", "rulesets", "ops", "safety"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "extends": { "type": "string" },
    "autonomy": {
      "type": "object",
      "required": ["enabled", "profile"],
      "properties": {
        "enabled": { "type": "boolean" },
        "profile": { "type": "string", "enum": ["off", "suggest", "source", "patch", "guarded", "full", "breakglass"] }
      },
      "additionalProperties": true
    },
    "repository_role": {
      "type": "object",
      "required": ["role", "source_of_truth_owner", "execution_owner"],
      "properties": {
        "role": { "type": "string", "enum": ["unknown", "canonical_source", "ci_cd_mirror", "control_plane", "org_native"] },
        "source_of_truth_owner": { "type": "string" },
        "execution_owner": { "type": "string" }
      },
      "additionalProperties": true
    },
    "agent": {
      "type": "object",
      "properties": {
        "patch": { "type": "boolean" },
        "patch_mode_on_check_run_failure": { "type": "string", "enum": ["auto", "suggest", "patch"] },
        "suggest_on_unclassified_failure": { "type": "boolean" },
        "max_iterations": { "type": "integer", "minimum": 1, "maximum": 10 },
        "rollback_on_regression": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "pr": {
      "type": "object",
      "properties": {
        "finalize": { "type": "boolean" },
        "merge": { "type": "boolean" },
        "merge_method": { "type": "string", "enum": ["merge", "squash", "rebase"] },
        "delete_branch": { "type": "boolean" },
        "require_clean_checks": { "type": "boolean" },
        "require_zero_pending_checks": { "type": "boolean" },
        "require_zero_unresolved_threads": { "type": "boolean" },
        "require_mergeable": { "type": "boolean" },
        "require_human_review": { "type": "boolean" },
        "allow_bot_review": { "type": "boolean" },
        "allow_review_dismissal": { "type": "boolean" },
        "allow_auto_merge": { "type": "boolean" },
        "allow_immediate_merge": { "type": "boolean" },
        "allow_bypass_ruleset": { "type": "boolean" },
        "require_expected_head_sha": { "type": "boolean" },
        "allow_fork_head": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "release": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "trigger_after_merge": { "type": "boolean" },
        "release_please": { "type": "boolean" },
        "merge_release_pr": { "type": "boolean" },
        "create_github_release": { "type": "boolean" },
        "require_release_plan_clean": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "publish": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "npm": { "type": "boolean" },
        "ghcr": { "type": "boolean" },
        "dockerhub": { "type": "boolean" },
        "vscode_marketplace": { "type": "boolean" },
        "open_vsx": { "type": "boolean" },
        "mcp_registry": { "type": "boolean" },
        "require_environment": { "type": "string" },
        "require_tag_pattern": { "type": "string" },
        "trusted_publishing_only": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "mirror": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "source_owner": { "type": "string" },
        "source_repo": { "type": "string" },
        "source_branch": { "type": "string" },
        "mirror_owner": { "type": "string" },
        "mirror_repo": { "type": "string" },
        "mirror_branch": { "type": "string" },
        "direction": { "type": "string", "enum": ["source_to_mirror"] },
        "promote_back": { "type": "boolean" },
        "promote_method": { "type": "string", "enum": ["pull_request"] },
        "delete_promote_branch": { "type": "boolean" },
        "require_source_mirror_sha_match_before_release": { "type": "boolean" },
        "require_source_mirror_sha_match_before_publish": { "type": "boolean" },
        "allow_mirror_only_closeout": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "properties": {
        "accepts_promoted_prs": { "type": "boolean" },
        "ci_delegated_to": { "type": "string" },
        "actions_expected_enabled": { "type": "boolean" },
        "require_clean_mirror_validation": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
